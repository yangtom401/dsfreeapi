{
  "name": "标准工具调用",
  "endpoint": "openai",
  "category": "basic",
  "models": ["deepseek-default", "deepseek-expert"],
  "request": {
    "messages": [
      {"role": "system", "content": "你是一个天气助手，使用 get_weather 工具查询天气。"},
      {"role": "user", "content": "北京今天天气怎么样？"}
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "get_weather",
          "description": "获取指定城市的天气信息",
          "parameters": {
            "type": "object",
            "properties": {
              "city": {"type": "string", "description": "城市名称"}
            },
            "required": ["city"]
          }
        }
      }
    ],
    "tool_choice": "auto",
    "stream": false
  },
  "checks": {
    "has_tool_calls": true,
    "finish_reason": "tool_calls"
  }
}
