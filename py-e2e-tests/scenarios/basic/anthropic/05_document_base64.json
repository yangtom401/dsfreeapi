{
  "name": "文档base64上传",
  "endpoint": "anthropic",
  "category": "basic",
  "models": [
    "deepseek-default",
    "deepseek-expert"
  ],
  "request": {
    "messages": [
      {
        "role": "user",
        "content": [
          {
            "type": "text",
            "text": "请简要概括这个文档的内容。"
          },
          {
            "type": "document",
            "source": {
              "type": "base64",
              "media_type": "text/plain",
              "data": ""
            }
          }
        ]
      }
    ],
    "max_tokens": 1024,
    "stream": false
  },
  "checks": {
    "content_not_empty": true,
    "stop_reason": "end_turn"
  }
}