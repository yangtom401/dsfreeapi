{
  "name": "图片HTTP链接",
  "endpoint": "anthropic",
  "category": "basic",
  "models": ["deepseek-default", "deepseek-expert"],
  "request": {
    "messages": [
      {"role": "user", "content": [
        {"type": "text", "text": "请访问这个网页，告诉我它包含什么内容。"},
        {"type": "image", "source": {"type": "url", "url": "https://example.com"}}
      ]}
    ],
    "max_tokens": 1024,
    "stream": false
  },
  "checks": {
    "content_not_empty": true,
    "stop_reason": "end_turn"
  }
}
